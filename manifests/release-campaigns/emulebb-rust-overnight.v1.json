      "id": "preflight",
      "title": "Preflight",
      "scenarios": [
        {
          "id": "emulebb.flow.rust.overnight.local-client.pytest.v1",
          "title": "Rust overnight local client pytest surface",
          "phase": "preflight",
          "flowCategory": "python-harness",
          "required": true,
          "blocking": true,
          "command": "python scripts/rust-overnight-pytest-proof.py",
          "evidence": [
            {
              "kind": "json-status",
              "required": true,
              "base": "workspace-output",
              "path": "reports/rust-overnight-pytest-proof/latest/rust-overnight-pytest-proof-result.json",
              "statusPointer": "/status",
              "matches": {
                "/checks/rust_overnight_pytest_requirements/caseCount": 2,
                "/checks/rust_overnight_pytest_requirements/allCasesPassed": true,
                "/checks/rust_overnight_pytest_requirements/localClientPytestPassed": true,
                "/checks/rust_overnight_pytest_requirements/restContractPytestPassed": true
              }
            }
          ]
        }
      ]
