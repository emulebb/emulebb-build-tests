          "title": "p2p-overlord CPU and memory stress",
          "phase": "stabilization-stress",
          "flowCategory": "stress",
          "required": false,
          "blocking": false,
          "command": "manual",
          "evidence": [
            {
              "kind": "manual",
              "required": false,
              "description": "Future resource runs should collect CPU, memory, handles, and REST counters separately from UMDH memory runs."
