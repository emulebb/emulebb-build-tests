        {
          "id": "emulebb.flow.workspace.validate.static.v1",
          "title": "Workspace validation and policy audits",
          "phase": "preflight",
          "flowCategory": "workspace-policy",
          "required": true,
          "blocking": true,
          "command": "python -m emule_workspace validate",
          "evidence": [
            {
              "kind": "manual",
              "required": true,
              "description": "Operator records the validate command result in the release checklist."
            }
          ]
        },
        {
          "id": "emulebb.flow.certification.fast.matrix.v1",
          "title": "Fast certification matrix",
          "phase": "preflight",
          "flowCategory": "build",
          "required": true,
          "blocking": true,
          "command": "python -m emule_workspace test certification --profile fast",
          "evidence": [
            {
              "kind": "json-status",
              "required": true,
              "base": "workspace-state",
              "glob": "certification/*-fast/result.json",
              "statusPointer": "/status"
            }
          ]
        },
        {
          "id": "emulebb.flow.python.harness.unit.v1",
          "title": "Python harness unit coverage",
          "phase": "preflight",
          "flowCategory": "python-harness",
          "required": true,
          "blocking": true,
          "command": "python -m emule_workspace test python --quiet",
          "evidence": [
            {
              "kind": "manual",
              "required": true,
              "description": "Covered directly and through certification; pytest output is recorded by the operator when run standalone."
            }
          ]
        },
        {
          "id": "emulebb.flow.release-coverage.ownership.v1",
          "title": "Release coverage ownership manifest",
          "phase": "preflight",
          "flowCategory": "coverage-ownership",
          "required": true,
          "blocking": true,
          "command": "python -m emule_workspace test python --quiet",
          "evidence": [
            {
              "kind": "manual",
              "required": true,
              "description": "Python harness validates the release coverage ownership manifest against campaign scenarios."
            }
          ]
        }
      ]
